# ─── Required ────────────────────────────────────────────────────────────────
# Path to your local PC photos folder
PC_PHOTOS_DIR=/Users/yourname/Pictures

# Path where your HRP (high-resolution) photos will be stored
HRP_FOLDER=/Users/yourname/Pictures/HRP

# ─── Optional: Mobile ─────────────────────────────────────────────────────────
# Uncomment and set the path where your phone mounts via USB-C (File Transfer mode)
# On macOS: /Volumes/YourPhone
# On Linux: /media/youruser/YourPhone
# MOBILE_MOUNT_PATH=path/to/your/phone/mount

# ─── Detection settings ───────────────────────────────────────────────────────
# Max Hamming distance between pHashes to consider two photos duplicates
# 0 = byte-identical, ≤5 = near-certain, ≤10 = same scene/slight edit (recommended)
HAMMING_THRESHOLD=10

# Local/cloud pixel ratio to trigger an HRP move (1.2 = 20% more pixels)
HRP_RATIO=1.2

# ─── Execution ────────────────────────────────────────────────────────────────
# Default dry-run. Set to false only when you're ready to execute.
DRY_RUN=true

# Uncomment to cap the max number of delete actions per run (safety net)
# MAX_DELETES=50

# ─── Google Photos OAuth ─────────────────────────────────────────────────────
# Path to your client_secret.json from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=client_secret.json
# Token is saved here after first auth (keep out of project dir)
# GOOGLE_TOKEN_PATH=/Users/yourname/.photo_agent_token.json

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
