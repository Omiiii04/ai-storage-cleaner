# ─── Required ────────────────────────────────────────────────────────────────
# Path to your local PC photos folder
PC_PHOTOS_DIR=/Users/yourname/Pictures

# Path where your HRP (high-resolution) photos will be stored
HRP_FOLDER=/Users/yourname/Pictures/HRP

# ─── Optional: Mobile (Android via ADB) ───────────────────────────────────────
# Android phones use MTP over USB, which isn't a real filesystem mount —
# this project talks to the phone via ADB (Android Debug Bridge) instead.
# Setup: enable Developer Options + USB Debugging on the phone, install
# Android Platform Tools, then run `python main.py mobile-status` to verify.
# Leave these as defaults unless you know you need to change them.

# Remote folder on the phone to scan
ANDROID_REMOTE_DIR=/sdcard/DCIM

# Only needed if you have multiple devices connected — see `adb devices -l`
# ANDROID_DEVICE_SERIAL=

# On-device folder where soft-deleted mobile photos are moved (never hard-deleted)
ANDROID_TRASH_DIR=/sdcard/.photo_agent_trash

# Off by default for safety. When false, mobile duplicates that would
# otherwise be deleted are SKIPped instead — delete manually via your
# phone's gallery app, or set this to true once you trust the agent's calls.
ENABLE_MOBILE_DELETE=false

# ─── Detection settings ───────────────────────────────────────────────────────
# Max Hamming distance between pHashes to consider two photos duplicates
# 0 = byte-identical, ≤5 = near-certain, ≤10 = same scene/slight edit (recommended)
HAMMING_THRESHOLD=10

# Local/cloud pixel ratio to trigger an HRP move (1.2 = 20% more pixels)
HRP_RATIO=1.2

# ─── Execution ────────────────────────────────────────────────────────────────
# Default dry-run. Set to false only when you're ready to execute.
DRY_RUN=true

# Uncomment to cap the max number of delete actions per run (safety net)
# MAX_DELETES=50

# ─── Google Photos OAuth ─────────────────────────────────────────────────────
# Path to your client_secret.json from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=client_secret.json
# Token is saved here after first auth (keep out of project dir)
# GOOGLE_TOKEN_PATH=/Users/yourname/.photo_agent_token.json

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
